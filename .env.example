# CMiC Configuration
# Copy this file to .env and fill in your actual values.
# Variable names follow the tap's setting keys; run `tap-cmic --about` for the
# authoritative list.

# Required: CMiC username
TAP_CMIC_USERNAME=your_username_here

# Required: CMiC password
TAP_CMIC_PASSWORD=your_password_here

# Optional: The earliest record date to sync (ISO-8601)
TAP_CMIC_START_DATE=2023-01-01T00:00:00Z

# Optional: API base URL (defaults to https://partner-sandbox-api-basic.cmiccloud.com/cmicprtn)
TAP_CMIC_API_URL=https://partner-sandbox-api-basic.cmiccloud.com/cmicprtn
