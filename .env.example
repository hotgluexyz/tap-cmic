# CMiC Configuration
# Copy this file to .env and fill in your actual values.
# Variable names follow the tap's setting keys; run `tap-cmic --about` for the
# authoritative list.

# Required: CMiC API service account username
TAP_CMIC_USER=your_api_service_account_here

# Required: CMiC password
TAP_CMIC_PASSWORD=your_password_here

# Optional: The earliest record date to sync (ISO-8601)
TAP_CMIC_START_DATE=2023-01-01T00:00:00Z

# Required: CMiC Basic Auth API base URL (no trailing slash)
# See https://developers.cmicglobal.com/v1/docs/cloud-api-server-urls
TAP_CMIC_BASE_URL=https://atlas-api.cmiccloud.com/cmicprod
